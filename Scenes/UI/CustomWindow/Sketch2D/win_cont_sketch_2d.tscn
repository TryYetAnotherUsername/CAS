        if (propertyName == \"Thickness\") wall.Thickness = newValue;
    }

    // Refresh the 2D view so the visual lines/dots move!
    UiUpdateAll(); 
}

	// Create item methods
	private void CreateFloatEditItem(TreeItem parent, string key, float value)
