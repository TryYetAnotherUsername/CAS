	}

public void OnTreeItemEdit()
{
    var item = _Tree.GetEdited(); // Better than GetSelected for signal handling
    if (item == null) return;

    TreeItem parent = item.GetParent();
    if (parent == null) return;

    TreeItem grandParent = parent.GetParent();
    if (grandParent == null) return;

    // Use the Grandparent's text to decide the \"Category\"
    string category = grandParent.GetText(0);
    
    // Grab the ID we stored in the \"Vertex/Wall ID X\" item
    int id = parent.GetMetadata(0).AsInt32();
    
    string propertyName = item.GetText(0);
    float newValue = item.GetText(1).ToFloat();

