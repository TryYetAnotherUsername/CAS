		item.SetText(1, value.ToString());
	}

	private void CreateLabelItem(TreeItem parent, string key, string value)
	{
		var item = _Tree.CreateItem(parent);
		item.SetText(0, key);
		item.SetText(1, value);
	}

*/

}"

