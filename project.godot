[layer_names]

3d_physics/layer_1="Physics"
3d_physics/layer_2="Interaction"
3d_physics/layer_3="Gizmos"

[navigation]

3d/default_cell_size=0.001
3d/default_cell_height=0.001

[physics]

3d/physics_engine="Jolt Physics"
3d/default_gravity=15.0

[rendering]

lights_and_shadows/directional_shadow/size=16384
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=4
lights_and_shadows/directional_shadow/16_bits=false
