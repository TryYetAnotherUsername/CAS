; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Commercial architecture simulator"
config/tags=PackedStringArray("development")
run/main_scene="uid://be3ed6b05d2ej"
config/features=PackedStringArray("4.5", "C#", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/per_pixel_transparency/allowed=true

[dotnet]

project/assembly_name="Commercial architecture simulator"

[editor_plugins]

enabled=PackedStringArray("res://addons/voronoi_scatter/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/": "purple",
"res://Scenes/": "teal",
"res://Scripts/": "gray",
"res://Scripts/Controllers/": "gray",
"res://Scripts/Managers/": "red"
}

[filesystem]

import/blender/enabled=false

[gui]

timers/incremental_search_max_interval_msec=1
theme/default_font_antialiasing=2
theme/default_font_hinting=2
theme/default_font_multichannel_signed_distance_field=true
theme/default_font_generate_mipmaps=true
theme/custom_font="uid://baq63qqcvy88f"

[importer_defaults]

texture={
&"process/channel_remap/blue": 10,
&"process/channel_remap/green": 10,
&"process/channel_remap/red": 10
}

